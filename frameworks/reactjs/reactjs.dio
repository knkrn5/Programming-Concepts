                <mxCell id="16" value="2. when the component is unmounted" style="text;strokeColor=default;fillColor=none;align=left;verticalAlign=middle;spacingLeft=4;spacingRight=4;overflow=hidden;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;rotatable=0;whiteSpace=wrap;html=1;dashed=1;dashPattern=1 4;" vertex="1" parent="12">
                    <mxGeometry y="70" width="250" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="17" value="&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: light-dark(#ffffff, var(--ge-dark-color, #121212));&quot;&gt;In react, except index.html&lt;/font&gt;&lt;div&gt;&lt;font style=&quot;background-color: light-dark(#ffffff, var(--ge-dark-color, #121212));&quot;&gt;&lt;font style=&quot;color: light-dark(rgb(192, 192, 192), rgb(255, 255, 255));&quot;&gt;&lt;span style=&quot;color: rgb(192, 192, 192);&quot;&gt;There are no real pages. It&#39;s all &lt;/span&gt;&lt;strong style=&quot;color: rgb(192, 192, 192);&quot;&gt;JavaScript DOM manipulatio&lt;/strong&gt;&lt;/font&gt;&lt;strong style=&quot;color: rgb(192, 192, 192);&quot;&gt;n&lt;/strong&gt;&lt;span style=&quot;color: rgb(192, 192, 192);&quot;&gt;.&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=default;fillColor=none;" vertex="1" parent="1">
                    <mxGeometry x="120" y="560" width="370" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="18" value="&lt;li class=&quot;font-claude-response-body whitespace-normal break-words pl-2&quot;&gt;&lt;strong&gt;React Router&lt;/strong&gt; (or whatever router) intercepts it — no real browser navigation happens&lt;/li&gt;&lt;br/&gt;&lt;li class=&quot;font-claude-response-body whitespace-normal break-words pl-2&quot;&gt;It reads &lt;code class=&quot;bg-text-200/5 border border-0.5 border-border-300 text-danger-000 whitespace-pre-wrap rounded-[0.4rem] px-1 py-px text-[0.9rem]&quot;&gt;window.location.pathname&lt;/code&gt; (e.g. &lt;code class=&quot;bg-text-200/5 border border-0.5 border-border-300 text-danger-000 whitespace-pre-wrap rounded-[0.4rem] px-1 py-px text-[0.9rem]&quot;&gt;/dashboard&lt;/code&gt;)&lt;/li&gt;&lt;br/&gt;&lt;li class=&quot;font-claude-response-body whitespace-normal break-words pl-2&quot;&gt;It calls &lt;code class=&quot;bg-text-200/5 border border-0.5 border-border-300 text-danger-000 whitespace-pre-wrap rounded-[0.4rem] px-1 py-px text-[0.9rem]&quot;&gt;ReactDOM&lt;/code&gt; to &lt;strong&gt;unmount&lt;/strong&gt; the current component tree and &lt;strong&gt;mount&lt;/strong&gt; a new one&lt;/li&gt;&lt;br/&gt;&lt;li class=&quot;font-claude-response-body whitespace-normal break-words pl-2&quot;&gt;The DOM updates — looks like a new page, but it&#39;s just JS swapping components&lt;/li&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=default;fillColor=none;" vertex="1" parent="1">
