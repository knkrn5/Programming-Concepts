                <mxCell id="3" value="&lt;b&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;Power ON&lt;/font&gt;&lt;/b&gt;" style="ellipse;whiteSpace=wrap;html=1;" vertex="1" parent="1">
                    <mxGeometry x="280" y="430" width="110" height="60" as="geometry"/>
