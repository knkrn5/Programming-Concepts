                <mxCell id="2" value="&lt;h1&gt;&lt;font face=&quot;Times New Roman&quot;&gt;Boot process&lt;/font&gt;&lt;/h1&gt;" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
