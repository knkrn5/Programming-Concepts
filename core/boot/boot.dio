                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="20" value="2 — PEI (Pre-EFI Initialization)" style="swimlane;fontStyle=0;childLayout=stackLayout;horizontal=1;startSize=30;horizontalStack=0;resizeParent=1;resizeParentMax=0;resizeLast=0;collapsible=1;marginBottom=0;whiteSpace=wrap;html=1;rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="1" vertex="1">
                    <mxGeometry x="660" y="1370" width="240" height="80" as="geometry">
