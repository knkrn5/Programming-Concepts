                    </mxGeometry>
                </mxCell>
                <mxCell id="29" value="1. pnpm link the files using hard links and symlinks" style="text;strokeColor=default;fillColor=none;align=left;verticalAlign=middle;spacingLeft=4;spacingRight=4;overflow=hidden;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;rotatable=0;whiteSpace=wrap;html=1;dashed=1;dashPattern=1 4;" parent="7" vertex="1">
                    <mxGeometry y="30" width="300" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="27" value="&lt;b&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;packages mapping&lt;/font&gt;&lt;/b&gt;" style="swimlane;fontStyle=0;childLayout=stackLayout;horizontal=1;startSize=30;horizontalStack=0;resizeParent=1;resizeParentMax=0;resizeLast=0;collapsible=1;marginBottom=0;whiteSpace=wrap;html=1;rounded=1;fillColor=#cce5ff;strokeColor=#36393d;" parent="1" vertex="1">
                    <mxGeometry x="510" y="-140" width="300" height="140" as="geometry">
                        <mxRectangle x="130" y="-30" width="110" height="30" as="alternateBounds"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="25" value="2.&amp;nbsp;pnpm maintains a SQLite-backed index (&lt;span style=&quot;background-color: light-dark(rgb(255, 255, 255), rgb(255, 102, 255));&quot;&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(0, 0, 0));&quot;&gt;index.db&lt;/font&gt;&lt;/span&gt;) to map package identifiers like tarball integrity to the list of files they contain" style="text;strokeColor=default;fillColor=none;align=left;verticalAlign=middle;spacingLeft=4;spacingRight=4;overflow=hidden;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;rotatable=0;whiteSpace=wrap;html=1;dashed=1;dashPattern=1 4;" parent="27" vertex="1">
                    <mxGeometry y="30" width="300" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="28" value="3.&amp;nbsp;pnpm just looks up that known hash against its local store index — if a match exists, it skips the download entirely and links straight from the store" style="text;strokeColor=default;fillColor=none;align=left;verticalAlign=middle;spacingLeft=4;spacingRight=4;overflow=hidden;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;rotatable=0;whiteSpace=wrap;html=1;dashed=1;dashPattern=1 4;" parent="27" vertex="1">
                    <mxGeometry y="80" width="300" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="12" value="&lt;b style=&quot;&quot;&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(0, 0, 0));&quot;&gt;local projects&lt;/font&gt;&lt;/b&gt;" style="swimlane;fontStyle=0;childLayout=stackLayout;horizontal=1;startSize=30;horizontalStack=0;resizeParent=1;resizeParentMax=0;resizeLast=0;collapsible=1;marginBottom=0;whiteSpace=wrap;html=1;rounded=1;fillColor=#d80073;fontColor=#ffffff;strokeColor=#A50040;" parent="1" vertex="1">
                    <mxGeometry x="20" y="690" width="300" height="80" as="geometry">
                        <mxRectangle x="264" y="490" width="110" height="30" as="alternateBounds"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="13" value="1.&amp;nbsp;" style="text;strokeColor=default;fillColor=none;align=left;verticalAlign=middle;spacingLeft=4;spacingRight=4;overflow=hidden;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;rotatable=0;whiteSpace=wrap;html=1;dashed=1;dashPattern=1 4;" parent="12" vertex="1">
                    <mxGeometry y="30" width="300" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="26" style="edgeStyle=none;html=1;exitX=0.75;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" parent="1" source="21" target="27" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="35" style="edgeStyle=none;html=1;entryX=1;entryY=0.138;entryDx=0;entryDy=0;entryPerimeter=0;" parent="1" target="33" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="250" y="100" as="sourcePoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="71" style="edgeStyle=none;html=1;exitX=0.997;exitY=0.113;exitDx=0;exitDy=0;entryX=0;entryY=0;entryDx=0;entryDy=0;exitPerimeter=0;" edge="1" parent="1" source="21" target="45">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="21" value="&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;b style=&quot;&quot;&gt;Packages Storing Architecture&lt;/b&gt;&lt;/font&gt;" style="swimlane;fontStyle=0;childLayout=stackLayout;horizontal=1;startSize=30;horizontalStack=0;resizeParent=1;resizeParentMax=0;resizeLast=0;collapsible=1;marginBottom=0;whiteSpace=wrap;html=1;rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;gradientColor=#97d077;" parent="1" vertex="1">
                    <mxGeometry x="250" y="90" width="300" height="130" as="geometry">
                        <mxRectangle x="350" y="160" width="110" height="30" as="alternateBounds"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="22" value="1.&amp;nbsp;pnpm uses a content-addressable store. Files are stored according to a hash of their contents&lt;div&gt;&lt;ul&gt;&lt;li&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;now even if two package have same content, their hash will always be same&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;" style="text;strokeColor=default;fillColor=none;align=left;verticalAlign=middle;spacingLeft=4;spacingRight=4;overflow=hidden;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;rotatable=0;whiteSpace=wrap;html=1;dashed=1;dashPattern=1 4;" parent="21" vertex="1">
                    <mxGeometry y="30" width="300" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="33" value="&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;b style=&quot;&quot;&gt;pnpm hashing Architecture&lt;/b&gt;&lt;/font&gt;" style="swimlane;fontStyle=0;childLayout=stackLayout;horizontal=1;startSize=30;horizontalStack=0;resizeParent=1;resizeParentMax=0;resizeLast=0;collapsible=1;marginBottom=0;whiteSpace=wrap;html=1;rounded=1;fillColor=#ffcccc;strokeColor=#36393d;" parent="1" vertex="1">
                    <mxGeometry x="-180" y="50" width="300" height="130" as="geometry">
                        <mxRectangle x="350" y="160" width="110" height="30" as="alternateBounds"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="34" value="&lt;ol&gt;&lt;li&gt;pnpm generates the hash of the content in a folder and&amp;nbsp; the first two char becomes the name of the file&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;background-color: light-dark(rgb(255, 255, 255), rgb(0, 255, 255));&quot;&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(0, 0, 0));&quot;&gt;Per-file hashing, not per-package hashing&lt;/font&gt;&lt;/span&gt;: -&lt;/li&gt;&lt;/ol&gt;" style="text;strokeColor=default;fillColor=none;align=left;verticalAlign=middle;spacingLeft=4;spacingRight=4;overflow=hidden;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;rotatable=0;whiteSpace=wrap;html=1;dashed=1;dashPattern=1 4;" parent="33" vertex="1">
                    <mxGeometry y="30" width="300" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="39" value="&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;b style=&quot;&quot;&gt;pnpm hashing Architecture&lt;/b&gt;&lt;/font&gt;" style="swimlane;fontStyle=0;childLayout=stackLayout;horizontal=1;startSize=30;horizontalStack=0;resizeParent=1;resizeParentMax=0;resizeLast=0;collapsible=1;marginBottom=0;whiteSpace=wrap;html=1;rounded=1;fillColor=#ffcccc;strokeColor=#36393d;" parent="1" vertex="1">
                    <mxGeometry x="-670" y="330" width="360" height="210" as="geometry">
                        <mxRectangle x="350" y="160" width="110" height="30" as="alternateBounds"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="40" value="&lt;span style=&quot;color: rgb(250, 250, 250); font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, sans-serif; font-size: 14px; background-color: rgb(22, 22, 22);&quot;&gt;So if two versions of &lt;/span&gt;&lt;code style=&quot;box-sizing: border-box; border: 0px solid; margin: 0px; padding: 2px 4px; font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, &amp;quot;Liberation Mono&amp;quot;, &amp;quot;Courier New&amp;quot;, monospace; font-feature-settings: normal; font-variation-settings: normal; font-size: 14px; color: rgb(250, 250, 250); background: none 0% 0% / auto repeat scroll padding-box border-box oklch(0.985098 0.000048918 none / 0.08); -webkit-font-smoothing: antialiased; text-rendering: geometricprecision;&quot;&gt;lodash&lt;/code&gt;&lt;span style=&quot;color: rgb(250, 250, 250); font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, sans-serif; font-size: 14px; background-color: rgb(22, 22, 22);&quot;&gt; share 80% of their files, only the 20% new files get written; the rest are reused.&lt;/span&gt;&lt;div&gt;&lt;font face=&quot;ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, Segoe UI, sans-serif&quot; color=&quot;#161616&quot;&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/font&gt;&lt;div&gt;&lt;span style=&quot;color: rgb(250, 250, 250); font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, sans-serif; font-size: 14px; background-color: rgb(22, 22, 22);&quot;&gt;&lt;span style=&quot;color: rgb(250, 250, 250); background-color: rgb(22, 22, 22);&quot;&gt;&lt;span style=&quot;color: rgb(250, 250, 250); background-color: rgb(22, 22, 22);&quot;&gt;pnpm deduplicates at the &lt;/span&gt;&lt;span style=&quot;box-sizing: border-box; border: 0px solid; margin: 0px; padding: 0px; color: rgb(250, 250, 250); -webkit-font-smoothing: antialiased; text-rendering: geometricprecision; background-color: rgb(22, 22, 22);&quot;&gt;file level&lt;/span&gt;&lt;span style=&quot;color: rgb(250, 250, 250); background-color: rgb(22, 22, 22);&quot;&gt;, not the package level.,&amp;nbsp;&lt;/span&gt;This means upgrading a package only&lt;/span&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: rgb(250, 250, 250); font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, sans-serif; font-size: 14px; background-color: rgb(22, 22, 22);&quot;&gt;&lt;span style=&quot;color: rgb(250, 250, 250); background-color: rgb(22, 22, 22);&quot;&gt;&amp;nbsp;downloads/extracts the files that actually changed.&lt;/span&gt;&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;" style="text;strokeColor=default;fillColor=none;align=left;verticalAlign=middle;spacingLeft=4;spacingRight=4;overflow=hidden;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;rotatable=0;whiteSpace=wrap;html=1;dashed=1;dashPattern=1 4;" parent="39" vertex="1">
                    <mxGeometry y="30" width="360" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="41" value="" style="text;strokeColor=default;fillColor=none;align=left;verticalAlign=middle;spacingLeft=4;spacingRight=4;overflow=hidden;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;rotatable=0;whiteSpace=wrap;html=1;dashed=1;dashPattern=1 4;" parent="39" vertex="1">
                    <mxGeometry y="140" width="360" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="37" value="&lt;b&gt;Extra Info&lt;/b&gt;" style="swimlane;fontStyle=0;childLayout=stackLayout;horizontal=1;startSize=30;horizontalStack=0;resizeParent=1;resizeParentMax=0;resizeLast=0;collapsible=1;marginBottom=0;whiteSpace=wrap;html=1;rounded=1;fillColor=light-dark(#FFCCCC,#4C0099);strokeColor=#36393d;" parent="1" vertex="1">
                    <mxGeometry x="-680" y="-80" width="400" height="190" as="geometry">
                        <mxRectangle x="350" y="160" width="110" height="30" as="alternateBounds"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="38" value="&lt;span style=&quot;background-color: light-dark(rgb(255, 255, 255), rgb(0, 102, 102));&quot;&gt;pnpm still has to download the tarball from the registry &lt;/span&gt;(npm registry doesn&#39;t let you fetch individual files from a package). It always downloads and unpacks the&lt;span style=&quot;background-color: light-dark(rgb(255, 255, 255), rgb(0, 102, 102));&quot;&gt; full tarball into memory/temp&lt;/span&gt;. But when it&#39;s time to &lt;strong&gt;write files into the store / link them into &lt;code class=&quot;bg-text-200/5 border border-0.5 border-border-300 text-danger-000 whitespace-pre-wrap rounded-[0.4rem] px-1 py-px text-[0.9rem]&quot;&gt;node_modules&lt;/code&gt;&lt;/strong&gt;, that&#39;s where the dedup kicks in —&lt;span style=&quot;background-color: light-dark(rgb(255, 255, 255), rgb(0, 102, 102));&quot;&gt; unchanged files skip the write-to-disk step&lt;/span&gt; and &lt;span style=&quot;background-color: light-dark(rgb(255, 255, 255), rgb(0, 102, 102));&quot;&gt;just get relinked&lt;/span&gt;, and the actual &lt;code class=&quot;bg-text-200/5 border border-0.5 border-border-300 text-danger-000 whitespace-pre-wrap rounded-[0.4rem] px-1 py-px text-[0.9rem]&quot;&gt;node_modules&lt;/code&gt; population is hardlinks either way, not copies. So the &lt;span style=&quot;background-color: light-dark(#ffffff, var(--ge-dark-color, #121212));&quot;&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(102, 0, 204));&quot;&gt;savings are mainly in &lt;/font&gt;&lt;/span&gt;&lt;strong&gt;&lt;span style=&quot;background-color: light-dark(#ffffff, var(--ge-dark-color, #121212));&quot;&gt;&lt;span style=&quot;background-color: light-dark(#ffffff, var(--ge-dark-color, #121212));&quot;&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(102, 0, 204));&quot;&gt;disk space&lt;/font&gt;&lt;/span&gt; and&lt;/span&gt; node_modules population speed&lt;/strong&gt;, &lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(102, 0, 204));&quot;&gt;not network bandwidth&lt;/font&gt; (there are some registry-level tricks for reducing download size too, but that&#39;s separate from the store&#39;s content-addressing)." style="text;strokeColor=default;fillColor=none;align=left;verticalAlign=middle;spacingLeft=4;spacingRight=4;overflow=hidden;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;rotatable=0;whiteSpace=wrap;html=1;dashed=1;dashPattern=1 4;" parent="37" vertex="1">
                    <mxGeometry y="30" width="400" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="73" style="edgeStyle=none;html=1;exitX=0;exitY=0;exitDx=0;exitDy=0;entryX=1;entryY=0.75;entryDx=0;entryDy=0;" edge="1" parent="1" source="24" target="72">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="24" value="&lt;b style=&quot;scrollbar-color: rgb(75, 75, 75) rgb(27, 29, 30);&quot;&gt;&lt;font style=&quot;color: light-dark(rgb(192, 192, 192), rgb(255, 255, 255));&quot;&gt;pnpm packages Installation&lt;/font&gt;&lt;/b&gt;" style="swimlane;fontStyle=0;childLayout=stackLayout;horizontal=1;startSize=30;horizontalStack=0;resizeParent=1;resizeParentMax=0;resizeLast=0;collapsible=1;marginBottom=0;whiteSpace=wrap;html=1;rounded=1;fillColor=#e6d0de;strokeColor=#996185;gradientColor=#d5739d;" parent="1" vertex="1">
                    <mxGeometry x="-55" y="-310" width="360" height="280" as="geometry">
                        <mxRectangle x="460" y="-40" width="110" height="30" as="alternateBounds"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="8" value="1. pnpm stores/installs all the packages only once, in its store folder" style="text;strokeColor=default;fillColor=none;align=left;verticalAlign=middle;spacingLeft=4;spacingRight=4;overflow=hidden;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;rotatable=0;whiteSpace=wrap;html=1;dashed=1;dashPattern=1 4;" parent="24" vertex="1">
                    <mxGeometry y="30" width="360" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="32" value="&lt;ol&gt;&lt;li&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Before downloading: pnpm fetches the metadata of the package from the npm registry. This metadata includes the hash in data.integrity field&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Now pnpm check if any package with that same hash already exists, If yes then skip downloading and reuse that&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;If no, then pnpm downloads package tarball and calculates the tarball hash to verify integrity.&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;On success verificaiton pnpm then calculates the hashes of the files in that package to organize the content-addressable store.&lt;/font&gt;&lt;/li&gt;&lt;/ol&gt;" style="text;strokeColor=default;fillColor=none;align=left;verticalAlign=middle;spacingLeft=4;spacingRight=4;overflow=hidden;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;rotatable=0;whiteSpace=wrap;html=1;dashed=1;dashPattern=1 4;" parent="24" vertex="1">
                    <mxGeometry y="80" width="360" height="200" as="geometry"/>
                </mxCell>
                <mxCell id="14" value="&lt;b style=&quot;&quot;&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(0, 0, 0));&quot;&gt;global packages&lt;/font&gt;&lt;/b&gt;" style="swimlane;fontStyle=0;childLayout=stackLayout;horizontal=1;startSize=30;horizontalStack=0;resizeParent=1;resizeParentMax=0;resizeLast=0;collapsible=1;marginBottom=0;whiteSpace=wrap;html=1;rounded=1;fillColor=#1ba1e2;fontColor=#ffffff;strokeColor=#006EAF;" parent="1" vertex="1">
                    <mxGeometry x="480" y="680" width="300" height="80" as="geometry">
                        <mxRectangle x="264" y="490" width="110" height="30" as="alternateBounds"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="15" value="1.&amp;nbsp;" style="text;strokeColor=default;fillColor=none;align=left;verticalAlign=middle;spacingLeft=4;spacingRight=4;overflow=hidden;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;rotatable=0;whiteSpace=wrap;html=1;dashed=1;dashPattern=1 4;" parent="14" vertex="1">
                    <mxGeometry y="30" width="300" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="30" value="&lt;b style=&quot;&quot;&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(0, 0, 0));&quot;&gt;Practicals to do in PNPM&lt;/font&gt;&lt;/b&gt;" style="swimlane;fontStyle=0;childLayout=stackLayout;horizontal=1;startSize=30;horizontalStack=0;resizeParent=1;resizeParentMax=0;resizeLast=0;collapsible=1;marginBottom=0;whiteSpace=wrap;html=1;rounded=1;fillColor=light-dark(#E51400,#CC0000);fontColor=#ffffff;strokeColor=#B20000;" parent="1" vertex="1">
                    <mxGeometry x="280" y="950" width="300" height="80" as="geometry">
                        <mxRectangle x="264" y="490" width="110" height="30" as="alternateBounds"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="31" value="1.&amp;nbsp;" style="text;strokeColor=default;fillColor=none;align=left;verticalAlign=middle;spacingLeft=4;spacingRight=4;overflow=hidden;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;rotatable=0;whiteSpace=wrap;html=1;dashed=1;dashPattern=1 4;" parent="30" vertex="1">
                    <mxGeometry y="30" width="300" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="9" style="edgeStyle=none;html=1;exitX=0.55;exitY=0.95;exitDx=0;exitDy=0;exitPerimeter=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" parent="1" source="6" target="7" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="23" style="edgeStyle=none;html=1;exitX=0.4;exitY=0.1;exitDx=0;exitDy=0;exitPerimeter=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" parent="1" source="6" target="21" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="6" value="&lt;b&gt;&lt;font style=&quot;font-size: 20px;&quot;&gt;PNPM&lt;/font&gt;&lt;/b&gt;" style="ellipse;shape=cloud;whiteSpace=wrap;html=1;fillColor=#f8cecc;gradientColor=#ea6b66;strokeColor=#b85450;" parent="1" vertex="1">
                    <mxGeometry x="350" y="340" width="120" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="18" style="edgeStyle=none;html=1;exitX=0;exitY=0.25;exitDx=0;exitDy=0;entryX=1;entryY=0;entryDx=0;entryDy=0;strokeWidth=5;flowAnimation=1;" parent="1" source="16" target="2" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="36" value="&lt;p data-pm-slice=&quot;0 0 []&quot;&gt;so u r saying pnpm does not only calculate the hash of the each pacakges, instead it calculates teh hash of each and every file in that packages, so that later on when we download the different version of the same package, so instead of downloading the full packages with full files it will only download the files from that package those hash is not present and for the hash file it will just link those files to that newer version of that package&lt;/p&gt;" style="rounded=1;whiteSpace=wrap;html=1;" parent="1" vertex="1">
                    <mxGeometry x="-690" y="160" width="400" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="44" style="edgeStyle=none;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" parent="1" source="42" target="43" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="49" style="edgeStyle=none;html=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" parent="1" source="42" target="48" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="42" value="&lt;li&gt;&lt;p data-path-to-node=&quot;11,0,0&quot;&gt;&lt;b data-index-in-node=&quot;0&quot; data-path-to-node=&quot;11,0,0&quot;&gt;Downloads the full tarball:&lt;/b&gt; It pulls the complete &lt;code data-index-in-node=&quot;50&quot; data-path-to-node=&quot;11,0,0&quot;&gt;.tgz&lt;/code&gt; file for the new version from the npm registry.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p data-path-to-node=&quot;11,1,0&quot;&gt;&lt;b data-index-in-node=&quot;0&quot; data-path-to-node=&quot;11,1,0&quot;&gt;Extracts and hashes:&lt;/b&gt; It unpacks the tarball in a temporary location and calculates the hash of every single file.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p data-path-to-node=&quot;11,2,0&quot;&gt;&lt;b data-index-in-node=&quot;0&quot; data-path-to-node=&quot;11,2,0&quot;&gt;Compares to the global store:&lt;/b&gt; It checks if those file hashes already exist in your local &lt;code data-index-in-node=&quot;89&quot; data-path-to-node=&quot;11,2,0&quot;&gt;pnpm&lt;/code&gt; store.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p data-path-to-node=&quot;11,3,0&quot;&gt;&lt;b data-index-in-node=&quot;0&quot; data-path-to-node=&quot;11,3,0&quot;&gt;Saves only the diff:&lt;/b&gt; It takes any &lt;i data-index-in-node=&quot;34&quot; data-path-to-node=&quot;11,3,0&quot;&gt;new&lt;/i&gt; files (hashes it hasn&#39;t seen before) and saves them to the global store. It discards the downloaded files that it already has.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p data-path-to-node=&quot;11,4,0&quot;&gt;&lt;b data-index-in-node=&quot;0&quot; data-path-to-node=&quot;11,4,0&quot;&gt;Hard-links to &lt;code data-index-in-node=&quot;14&quot; data-path-to-node=&quot;11,4,0&quot;&gt;node_modules&lt;/code&gt;:&lt;/b&gt; Finally, it creates hard links in your project folder, pointing to the newly added files and the previously cached files.&lt;/p&gt;&lt;/li&gt;" style="rounded=1;whiteSpace=wrap;html=1;" parent="1" vertex="1">
                    <mxGeometry x="-690" y="630" width="610" height="280" as="geometry"/>
                </mxCell>
                <mxCell id="43" value="&lt;li class=&quot;font-claude-response-body whitespace-normal break-words pl-2&quot;&gt;pnpm fetches the new version&#39;s metadata/tarball.&lt;/li&gt;&lt;br/&gt;&lt;li class=&quot;font-claude-response-body whitespace-normal break-words pl-2&quot;&gt;For each file in that tarball, it computes the content hash.&lt;/li&gt;&lt;br/&gt;&lt;li class=&quot;font-claude-response-body whitespace-normal break-words pl-2&quot;&gt;It checks: does a file with this exact hash already exist in the store?&lt;br/&gt;&lt;ul class=&quot;[li_&amp;amp;]:mb-0 [li_&amp;amp;]:mt-1 [li_&amp;amp;]:gap-1 [&amp;amp;:not(:last-child)_ul]:pb-1 [&amp;amp;:not(:last-child)_ol]:pb-1 list-disc flex flex-col gap-1 pl-8 mb-3 print:block print:space-y-1&quot; dir=&quot;ltr&quot;&gt;&lt;br/&gt;&lt;li class=&quot;font-claude-response-body whitespace-normal break-words pl-2&quot;&gt;&lt;strong&gt;Yes&lt;/strong&gt; → skip writing it, just reuse the existing stored file (hardlink it into &lt;code class=&quot;bg-text-200/5 border border-0.5 border-border-300 text-danger-000 whitespace-pre-wrap rounded-[0.4rem] px-1 py-px text-[0.9rem]&quot;&gt;node_modules&lt;/code&gt; when needed).&lt;/li&gt;&lt;br/&gt;&lt;li class=&quot;font-claude-response-body whitespace-normal break-words pl-2&quot;&gt;&lt;strong&gt;No&lt;/strong&gt; → write this new file into the store under its new hash.&lt;/li&gt;&lt;br/&gt;&lt;/ul&gt;&lt;br/&gt;&lt;/li&gt;&lt;br/&gt;&lt;li class=&quot;font-claude-response-body whitespace-normal break-words pl-2&quot;&gt;So if you go from &lt;code class=&quot;bg-text-200/5 border border-0.5 border-border-300 text-danger-000 whitespace-pre-wrap rounded-[0.4rem] px-1 py-px text-[0.9rem]&quot;&gt;lodash@4.17.20&lt;/code&gt; → &lt;code class=&quot;bg-text-200/5 border border-0.5 border-border-300 text-danger-000 whitespace-pre-wrap rounded-[0.4rem] px-1 py-px text-[0.9rem]&quot;&gt;4.17.21&lt;/code&gt; and only 3 files changed internally, only those 3 files&#39; new hashes get added to the store. Every unchanged file (which is often the vast majority — license files, unchanged utility files, type defs, etc.) is instantly deduplicated against what&#39;s already sitting in the store from the old version, or even from a &lt;em&gt;completely different package&lt;/em&gt; that happens to ship an identical file.&lt;/li&gt;" style="rounded=1;whiteSpace=wrap;html=1;" parent="1" vertex="1">
                    <mxGeometry x="-715" y="1060" width="660" height="330" as="geometry"/>
                </mxCell>
                <mxCell id="47" style="edgeStyle=none;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" parent="1" source="45" target="46" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="45" value="&lt;ol style=&quot;box-sizing: border-box; border: 0px solid; margin: 8px 0px 12px; padding: 0px 0px 0px 2.25rem; list-style: outside decimal; -webkit-font-smoothing: antialiased; text-rendering: geometricprecision; font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, sans-serif; font-size: 14px; text-align: start; background-color: rgb(22, 22, 22);&quot;&gt;&lt;li style=&quot;box-sizing: border-box; border: 0px solid; margin: 0px 0px 8px; padding: 0px; -webkit-font-smoothing: antialiased; text-rendering: geometricprecision;&quot;&gt;&lt;p style=&quot;box-sizing: border-box; border: 0px solid; margin: 0px; padding: 0px; display: inline; -webkit-font-smoothing: antialiased; text-rendering: geometricprecision;&quot;&gt;&lt;font style=&quot;color: light-dark(rgb(250, 250, 250), rgb(255, 255, 255)); background-color: light-dark(rgb(22, 22, 22), rgb(0, 0, 153));&quot;&gt;&lt;span style=&quot;box-sizing: border-box; border: 0px solid; margin: 0px; padding: 0px; -webkit-font-smoothing: antialiased; text-rendering: geometricprecision; color: rgb(250, 250, 250);&quot;&gt;Avoids huge flat directories&lt;/span&gt; — A single project can have tens of thousands of files; putting all blobs in one dir would make filesystem lookups slow (ext4/NTFS do linear or hashed scans of directory entries).&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li style=&quot;box-sizing: border-box; border: 0px solid; margin: 0px 0px 8px; padding: 0px; -webkit-font-smoothing: antialiased; text-rendering: geometricprecision;&quot;&gt;&lt;p style=&quot;box-sizing: border-box; border: 0px solid; margin: 0px; padding: 0px; display: inline; -webkit-font-smoothing: antialiased; text-rendering: geometricprecision;&quot;&gt;&lt;font style=&quot;color: light-dark(rgb(250, 250, 250), rgb(255, 255, 255)); background-color: light-dark(rgb(22, 22, 22), rgb(0, 0, 153));&quot;&gt;&lt;span style=&quot;box-sizing: border-box; border: 0px solid; margin: 0px; padding: 0px; -webkit-font-smoothing: antialiased; text-rendering: geometricprecision; color: rgb(250, 250, 250);&quot;&gt;Even distribution&lt;/span&gt; — The hash is uniform, so the first byte distributes files roughly evenly across 256 buckets.&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li style=&quot;box-sizing: border-box; border: 0px solid; margin: 0px 0px 8px; padding: 0px; -webkit-font-smoothing: antialiased; text-rendering: geometricprecision;&quot;&gt;&lt;p style=&quot;box-sizing: border-box; border: 0px solid; margin: 0px; padding: 0px; display: inline; -webkit-font-smoothing: antialiased; text-rendering: geometricprecision;&quot;&gt;&lt;font style=&quot;color: light-dark(rgb(250, 250, 250), rgb(255, 255, 255)); background-color: light-dark(rgb(22, 22, 22), rgb(0, 0, 153));&quot;&gt;&lt;span style=&quot;box-sizing: border-box; border: 0px solid; margin: 0px; padding: 0px; -webkit-font-smoothing: antialiased; text-rendering: geometricprecision; color: rgb(250, 250, 250);&quot;&gt;File path layout&lt;/span&gt;: A blob is stored at &lt;code style=&quot;background-image: none; background-position: 0% 0%; background-size: auto; background-repeat: repeat; background-attachment: scroll; background-origin: padding-box; background-clip: border-box; box-sizing: border-box; border: 0px solid; margin: 0px; padding: 2px 4px; font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, &amp;quot;Liberation Mono&amp;quot;, &amp;quot;Courier New&amp;quot;, monospace; font-feature-settings: normal; font-variation-settings: normal; font-size: 1em; -webkit-font-smoothing: antialiased; text-rendering: geometricprecision; color: rgb(250, 250, 250);&quot;&gt;files/&amp;lt;first-2-hex-chars&amp;gt;/&amp;lt;full-hash&amp;gt;&lt;/code&gt;. For example: &lt;code style=&quot;background-image: none; background-position: 0% 0%; background-size: auto; background-repeat: repeat; background-attachment: scroll; background-origin: padding-box; background-clip: border-box; box-sizing: border-box; border: 0px solid; margin: 0px; padding: 2px 4px; font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, &amp;quot;Liberation Mono&amp;quot;, &amp;quot;Courier New&amp;quot;, monospace; font-feature-settings: normal; font-variation-settings: normal; font-size: 1em; -webkit-font-smoothing: antialiased; text-rendering: geometricprecision; color: rgb(162, 188, 255);&quot; data-inline-code-kind=&quot;path&quot;&gt;files/3f/3f9a1b2c...&lt;/code&gt;. The first byte determines the shard directory.&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ol&gt;" style="rounded=1;whiteSpace=wrap;html=1;" parent="1" vertex="1">
                    <mxGeometry x="990" y="210" width="560" height="220" as="geometry"/>
                </mxCell>
                <mxCell id="46" value="&lt;div&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;f&lt;b style=&quot;background-color: light-dark(rgb(255, 255, 255), rgb(0, 0, 102));&quot;&gt;ilesystem optimization called hash-based sharding or fan-out,&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;const hash&amp;nbsp; &amp;nbsp; = &quot;00cc06fe80fe136b07a2bcc082944...&quot;;&amp;nbsp; // just computed from file bytes&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;const dirName = hash.slice(0, 2);&amp;nbsp; &amp;nbsp;// &quot;00&quot;&amp;nbsp; &amp;lt;- deterministic, no guessing&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;const fileName = hash.slice(2);&amp;nbsp; &amp;nbsp; &amp;nbsp;// rest of hash&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;const fullPath = `store/v11/files/00/cc06fe80fe136b07a2bcc082944...`;&lt;/font&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;" parent="1" vertex="1">
                    <mxGeometry x="975" y="590" width="590" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="48" value="&lt;p&gt;so it will only check for the folder that will match the first 2hex of the fiel hash&lt;/p&gt;" style="rounded=1;whiteSpace=wrap;html=1;" parent="1" vertex="1">
                    <mxGeometry x="-1090" y="730" width="250" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="52" style="edgeStyle=none;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" parent="1" source="50" target="51" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="50" value="&lt;ol&gt;&lt;li&gt;pnpm builds a &quot;virtual store&quot; — &lt;code class=&quot;bg-text-200/5 border border-0.5 border-border-300 text-danger-000 whitespace-pre-wrap rounded-[0.4rem] px-1 py-px text-[0.9rem]&quot;&gt;node_modules/.pnpm&lt;/code&gt;&lt;/li&gt;&lt;li&gt;&lt;code class=&quot;bg-text-200/5 border border-0.5 border-border-300 text-danger-000 whitespace-pre-wrap rounded-[0.4rem] px-1 py-px text-[0.9rem]&quot;&gt;&amp;nbsp;Inside every project&#39;s &lt;code class=&quot;bg-text-200/5 border border-0.5 border-border-300 text-danger-000 whitespace-pre-wrap rounded-[0.4rem] px-1 py-px text-[0.9rem]&quot;&gt;node_modules&lt;/code&gt;, pnpm creates a hidden folder: &lt;code class=&quot;bg-text-200/5 border border-0.5 border-border-300 text-danger-000 whitespace-pre-wrap rounded-[0.4rem] px-1 py-px text-[0.9rem]&quot;&gt;node_modules/.pnpm/&lt;/code&gt;. This is where the &lt;em&gt;actual&lt;/em&gt; package contents live — one subfolder per exact package version:&lt;/code&gt;&lt;/li&gt;&lt;li&gt;&lt;code class=&quot;bg-text-200/5 border border-0.5 border-border-300 text-danger-000 whitespace-pre-wrap rounded-[0.4rem] px-1 py-px text-[0.9rem]&quot;&gt;For each package version, pnpm reads that package&#39;s index file and, for every entry, &lt;strong&gt;hardlinks&lt;/strong&gt; the corresponding content-hash file from &lt;code class=&quot;bg-text-200/5 border border-0.5 border-border-300 text-danger-000 whitespace-pre-wrap rounded-[0.4rem] px-1 py-px text-[0.9rem]&quot;&gt;store/v11/files/xx/...&lt;/code&gt; into &lt;code class=&quot;bg-text-200/5 border border-0.5 border-border-300 text-danger-000 whitespace-pre-wrap rounded-[0.4rem] px-1 py-px text-[0.9rem]&quot;&gt;node_modules/.pnpm/lodash@4.17.21/node_modules/lodash/index.js&lt;/code&gt; (etc.), reconstructing the &lt;em&gt;original folder structure&lt;/em&gt; of the package using its recorded relative paths, even though the store itself has no folder structure.&amp;nbsp;&lt;/code&gt;&lt;span style=&quot;background-color: light-dark(rgb(255, 255, 255), rgb(102, 0, 204));&quot;&gt;Repeat for every file in the package. Now you have a complete, real &lt;code style=&quot;&quot; class=&quot;bg-text-200/5 border border-0.5 border-border-300 text-danger-000 whitespace-pre-wrap rounded-[0.4rem] px-1 py-px text-[0.9rem]&quot;&gt;lodash&lt;/code&gt; package folder — just made of hardlinks instead of copies.&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;code class=&quot;bg-text-200/5 border border-0.5 border-border-300 text-danger-000 whitespace-pre-wrap rounded-[0.4rem] px-1 py-px text-[0.9rem]&quot;&gt;pnpm links top-level dependencies via symlinks: -&amp;nbsp;&amp;nbsp;&lt;/code&gt;Now your project&#39;s actual &lt;code class=&quot;bg-text-200/5 border border-0.5 border-border-300 text-danger-000 whitespace-pre-wrap rounded-[0.4rem] px-1 py-px text-[0.9rem]&quot;&gt;node_modules/lodash&lt;/code&gt; (the one your code does &lt;code class=&quot;bg-text-200/5 border border-0.5 border-border-300 text-danger-000 whitespace-pre-wrap rounded-[0.4rem] px-1 py-px text-[0.9rem]&quot;&gt;require(&#39;lodash&#39;)&lt;/code&gt; or &lt;code class=&quot;bg-text-200/5 border border-0.5 border-border-300 text-danger-000 whitespace-pre-wrap rounded-[0.4rem] px-1 py-px text-[0.9rem]&quot;&gt;import&lt;/code&gt; against) is &lt;strong&gt;not&lt;/strong&gt; a real folder — it&#39;s a &lt;strong&gt;symlink&lt;/strong&gt; pointing into &lt;code class=&quot;bg-text-200/5 border border-0.5 border-border-300 text-danger-000 whitespace-pre-wrap rounded-[0.4rem] px-1 py-px text-[0.9rem]&quot;&gt;.pnpm&amp;nbsp;&lt;span style=&quot;background-color: light-dark(rgb(255, 255, 255), rgb(102, 0, 204));&quot;&gt;node_modules/lodash → .pnpm/lodash@4.17.21/node_modules/lodash&lt;/span&gt;&lt;/code&gt;&lt;/li&gt;&lt;li&gt;&lt;code style=&quot;background-color: light-dark(rgb(255, 255, 255), rgb(0, 0, 0));&quot; class=&quot;bg-text-200/5 border border-0.5 border-border-300 text-danger-000 whitespace-pre-wrap rounded-[0.4rem] px-1 py-px text-[0.9rem]&quot;&gt;nested/transitive dependencies link to each other inside &lt;code style=&quot;&quot; class=&quot;bg-text-200/5 border border-0.5 border-border-300 text-danger-000 whitespace-pre-wrap rounded-[0.4rem] px-1 py-px text-[0.9rem]&quot;&gt;.pnpm: -&amp;nbsp;&lt;/code&gt;&lt;/code&gt;If &lt;code class=&quot;bg-text-200/5 border border-0.5 border-border-300 text-danger-000 whitespace-pre-wrap rounded-[0.4rem] px-1 py-px text-[0.9rem]&quot;&gt;lodash&lt;/code&gt; itself depended on some other package, that dependency would be symlinked &lt;em&gt;inside&lt;/em&gt; &lt;code class=&quot;bg-text-200/5 border border-0.5 border-border-300 text-danger-000 whitespace-pre-wrap rounded-[0.4rem] px-1 py-px text-[0.9rem]&quot;&gt;.pnpm/lodash@4.17.21/node_modules/&lt;/code&gt;, pointing to its own version folder elsewhere in &lt;code class=&quot;bg-text-200/5 border border-0.5 border-border-300 text-danger-000 whitespace-pre-wrap rounded-[0.4rem] px-1 py-px text-[0.9rem]&quot;&gt;.pnpm&lt;/code&gt;.&lt;/li&gt;&lt;/ol&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;" parent="1" vertex="1">
                    <mxGeometry x="30" y="1710" width="910" height="290" as="geometry"/>
                </mxCell>
                <mxCell id="53" style="edgeStyle=none;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" parent="1" source="51" target="54" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="485" y="2420" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="56" style="edgeStyle=none;html=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.25;entryDx=0;entryDy=0;" parent="1" source="51" target="55" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="51" value="&lt;p style=&quot;text-align: left;&quot;&gt;why cant pnpm directly hardlink in the main node_module folder for all the packages&lt;/p&gt;&lt;p style=&quot;text-align: left;&quot;&gt;&lt;/p&gt;&lt;ol&gt;&lt;li&gt;&lt;p&gt;what si the node_module structure of if project has depencises , then is depencise has depencies and so on&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Phantom dependencies (npm/yarn&#39;s actual known bug, which pnpm was explicitly designed to fix)&lt;/p&gt;&lt;/li&gt;&lt;/ol&gt;&lt;p&gt;&lt;/p&gt;&lt;p&gt;&lt;/p&gt;" style="rounded=1;whiteSpace=wrap;html=1;" parent="1" vertex="1">
                    <mxGeometry x="45" y="2120" width="880" height="200" as="geometry"/>
                </mxCell>
                <mxCell id="54" value="&lt;p&gt;what si the node_module structure of if project has depencises , then is depencise has depencies and so on&lt;/p&gt;&lt;p&gt;&lt;/p&gt;&lt;ol&gt;&lt;li&gt;&lt;br&gt;&lt;/li&gt;&lt;/ol&gt;&lt;p&gt;&lt;/p&gt;" style="rounded=1;whiteSpace=wrap;html=1;" parent="1" vertex="1">
                    <mxGeometry x="45" y="2440" width="885" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="58" style="edgeStyle=none;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" parent="1" source="55" target="57" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="55" value="Older versions of npm (before npm v3) nested dependencies deeply, but npm v3+ and Yarn Classic started &lt;strong data-end=&quot;612&quot; data-start=&quot;598&quot;&gt;flattening&lt;/strong&gt; dependencies whenever possible.&lt;div&gt;&lt;img alt=&quot;&quot; src=&quot;data:image/png;base64,&quot;&gt;&lt;img height=&quot;591&quot; width=&quot;898&quot; src=&quot;data:image/png;base64,&quot;&gt;&lt;font color=&quot;#ffffff&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;You never owned this dependency.&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;" parent="1" vertex="1">
                    <mxGeometry x="-870" y="1870" width="740" height="1160" as="geometry"/>
                </mxCell>
                <mxCell id="61" style="edgeStyle=none;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" parent="1" source="57" target="59" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="57" value="" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;" parent="1" vertex="1">
                    <mxGeometry x="-711.3199999999999" y="3100" width="401.32" height="319" as="geometry"/>
                </mxCell>
                <mxCell id="59" value="" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;" parent="1" vertex="1">
                    <mxGeometry x="-700" y="3507" width="390" height="407.84" as="geometry"/>
                </mxCell>
                <mxCell id="64" style="edgeStyle=none;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" parent="1" source="62" target="63" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="66" style="edgeStyle=none;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" parent="1" source="62" target="65" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="62" value="npm &lt;strong data-end=&quot;142&quot; data-start=&quot;129&quot;&gt;before v3&lt;/strong&gt; (nested dependencies): -&amp;nbsp;Before npm v3, dependencies were nested exactly according to the dependency graph.&lt;div&gt;&lt;ol&gt;&lt;li&gt;&lt;h3 class=&quot;PDq2pG_selectionAnchorContainer&quot; data-end=&quot;722&quot; data-start=&quot;698&quot; data-section-id=&quot;qex817&quot;&gt;Problems with npm v2&lt;span class=&quot;PDq2pG_selectionAnchor&quot; aria-hidden=&quot;true&quot;&gt;&lt;/span&gt;&lt;/h3&gt;&lt;br/&gt;&lt;ul data-end=&quot;863&quot; data-start=&quot;724&quot;&gt;&lt;br/&gt;&lt;li data-end=&quot;753&quot; data-start=&quot;724&quot; data-section-id=&quot;u4mn2t&quot;&gt;&lt;br/&gt;Lots of duplicate packages.&lt;br/&gt;&lt;/li&gt;&lt;br/&gt;&lt;li data-end=&quot;785&quot; data-start=&quot;754&quot; data-section-id=&quot;13nfye4&quot;&gt;&lt;br/&gt;Deeply nested &lt;code data-end=&quot;784&quot; data-start=&quot;770&quot;&gt;node_modules&lt;/code&gt;.&lt;br/&gt;&lt;/li&gt;&lt;br/&gt;&lt;li data-end=&quot;863&quot; data-start=&quot;786&quot; data-section-id=&quot;a876bw&quot;&gt;&lt;br/&gt;Windows often hit the &lt;code data-end=&quot;820&quot; data-start=&quot;810&quot;&gt;MAX_PATH&lt;/code&gt; limit because paths became extremely long.&lt;/li&gt;&lt;/ul&gt;&lt;/li&gt;&lt;/ol&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;" parent="1" vertex="1">
                    <mxGeometry x="1110" y="1676.87" width="680" height="310" as="geometry"/>
                </mxCell>
                <mxCell id="63" value="" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;" parent="1" vertex="1">
                    <mxGeometry x="1930" y="1763.74" width="335" height="136.26" as="geometry"/>
                </mxCell>
                <mxCell id="65" value="&amp;nbsp;npm v3+ (flattened): -&amp;nbsp;&lt;div&gt;&lt;ol&gt;&lt;li&gt;Starting with npm v3, npm tried to &lt;strong data-end=&quot;941&quot; data-start=&quot;932&quot;&gt;hoist&lt;/strong&gt; as many dependencies as possible to the top level.&lt;/li&gt;&lt;li&gt;This solved the deep nesting problem, but introduced the &lt;strong data-end=&quot;1168&quot; data-start=&quot;1146&quot;&gt;phantom dependency&lt;/strong&gt; problem because your app could now accidentally access &lt;code data-end=&quot;1236&quot; data-start=&quot;1224&quot;&gt;picocolors&lt;/code&gt;.&lt;/li&gt;&lt;/ol&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;" parent="1" vertex="1">
                    <mxGeometry x="1167" y="2110" width="566" height="180" as="geometry"/>
                </mxCell>
                <mxCell id="69" style="edgeStyle=none;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" parent="1" source="67" target="68" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="67" value="" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;" parent="1" vertex="1">
                    <mxGeometry x="1230" y="2430" width="326" height="210" as="geometry"/>
                </mxCell>
                <mxCell id="70" style="edgeStyle=none;html=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.75;entryDx=0;entryDy=0;flowAnimation=1;" parent="1" source="68" target="55" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="850" y="2840" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="68" value="Here the structure is same as npmV2, only difference that the files are not getting duplicated here like npm" style="rounded=1;whiteSpace=wrap;html=1;" parent="1" vertex="1">
                    <mxGeometry x="1230" y="2740" width="380" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="72" value="&lt;li class=&quot;font-claude-response-body whitespace-normal break-words pl-2&quot;&gt;Read &lt;code class=&quot;bg-text-200/5 border border-0.5 border-border-300 text-danger-000 whitespace-pre-wrap rounded-[0.4rem] px-1 py-px text-[0.9rem]&quot;&gt;package.json&lt;/code&gt; + &lt;code class=&quot;bg-text-200/5 border border-0.5 border-border-300 text-danger-000 whitespace-pre-wrap rounded-[0.4rem] px-1 py-px text-[0.9rem]&quot;&gt;pnpm-lock.yaml&lt;/code&gt; → resolve the full graph of exact versions needed (&lt;strong&gt;resolved&lt;/strong&gt;).&lt;/li&gt;&lt;br/&gt;&lt;li class=&quot;font-claude-response-body whitespace-normal break-words pl-2&quot;&gt;For each resolved version, check: does its per-package index/manifest already exist in the local store? If yes → skip network, just link (&lt;strong&gt;reused&lt;/strong&gt;).&lt;/li&gt;&lt;br/&gt;&lt;li class=&quot;font-claude-response-body whitespace-normal break-words pl-2&quot;&gt;If not present locally → fetch the tarball from the registry, verify integrity, unpack, hash each file, store (&lt;strong&gt;downloaded&lt;/strong&gt;).&lt;/li&gt;&lt;br/&gt;&lt;li class=&quot;font-claude-response-body whitespace-normal break-words pl-2&quot;&gt;Link everything into this project&#39;s &lt;code class=&quot;bg-text-200/5 border border-0.5 border-border-300 text-danger-000 whitespace-pre-wrap rounded-[0.4rem] px-1 py-px text-[0.9rem]&quot;&gt;node_modules&lt;/code&gt;/&lt;code class=&quot;bg-text-200/5 border border-0.5 border-border-300 text-danger-000 whitespace-pre-wrap rounded-[0.4rem] px-1 py-px text-[0.9rem]&quot;&gt;.pnpm&lt;/code&gt; (&lt;strong&gt;added&lt;/strong&gt;).&lt;/li&gt;" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
                    <mxGeometry x="-790" y="-490" width="570" height="230" as="geometry"/>
                </mxCell>
                <mxCell id="74" value="pnpm maintains metadata about what&#39;s already in its store." style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
                    <mxGeometry x="-770" y="-740" width="530" height="220" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
</mxfile>